# Local developer override. Safe defaults; copy from .env.example when needed.
APP_ENV=local
QAI_USE_QUEUE=0
QAI_RUN_MIGRATIONS=0
DATABASE_URL=sqlite:///outputs/service_state.sqlite
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=qai-artifacts
S3_ACCESS_KEY_ID=qaiadmin
S3_SECRET_ACCESS_KEY=qaiadmin123
S3_REGION=us-east-1
JWT_SECRET=dev-secret-change-me
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
