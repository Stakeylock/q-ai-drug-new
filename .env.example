# Development defaults only. Do not use these secrets in staging or production.
APP_ENV=local
QAI_API_PORT=8000
QAI_OUTPUT_DIR=/app/outputs/cancer_proof_v1
QAI_MODELS_DIR=/app/models
QAI_USE_QUEUE=1
QAI_RUN_MIGRATIONS=1

DATABASE_URL=postgresql+psycopg://qai:qai_dev_password@postgres:5432/qai_drug
POSTGRES_DB=qai_drug
POSTGRES_USER=qai
POSTGRES_PASSWORD=qai_dev_password
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

S3_ENDPOINT=http://minio:9000
S3_BUCKET=qai-artifacts
S3_ACCESS_KEY_ID=qaiadmin
S3_SECRET_ACCESS_KEY=qaiadmin123
S3_REGION=us-east-1
MINIO_ROOT_USER=qaiadmin
MINIO_ROOT_PASSWORD=qaiadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

JWT_SECRET=dev-secret-change-me
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
MAX_JOB_RUNTIME=86400
MAX_UPLOAD_SIZE=104857600
