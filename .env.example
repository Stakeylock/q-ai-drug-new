# Development defaults only. Do not use these secrets in staging or production.
APP_ENV=local
QAI_API_PORT=8000
QAI_OUTPUT_DIR=/app/outputs/cancer_proof_v1
QAI_MODELS_DIR=/app/models
QAI_USE_QUEUE=1
QAI_RUN_MIGRATIONS=1

DATABASE_URL=postgresql+psycopg://qai:qai_dev_password@postgres:5432/qai_drug
POSTGRES_DB=qai_drug
POSTGRES_USER=qai
POSTGRES_PASSWORD=qai_dev_password
POSTGRES_PORT=5432

QAI_MONGO_ENABLED=1
QAI_MONGO_REQUIRED=1
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=qai_drug_dev
MONGODB_TIMEOUT_MS=1200
MONGODB_PORT=27017

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

S3_ENDPOINT=http://minio:9000
S3_BUCKET=qai-artifacts
S3_ACCESS_KEY_ID=qaiadmin
S3_SECRET_ACCESS_KEY=qaiadmin123
S3_REGION=us-east-1
MINIO_ROOT_USER=qaiadmin
MINIO_ROOT_PASSWORD=qaiadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

JWT_SECRET=dev-secret-change-me
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
MAX_JOB_RUNTIME=86400
MAX_UPLOAD_SIZE=104857600

# Google AI Studio powers user-front Copilot chat.
# NVIDIA NIM powers ESM2 protein sequence embeddings and optional DiffusionGemma visual QA.
# MedGemma must be served through a private/local OpenAI-compatible endpoint after accepting its Hugging Face terms.
# Put real keys only in your private backend environment, never in React/Vite.
GOOGLE_AI_API_KEY=
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_AI_MODEL=gemma-4-31b-it
GOOGLE_AI_TIMEOUT_SECONDS=35
NVIDIA_API_KEY=
NVIDIA_ESM2_URL=https://health.api.nvidia.com/v1/biology/meta/esm2-650m
NVIDIA_ESM2_MODEL=meta/esm2-650m
DGEMMA_API_KEY=
DGEMMA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
DGEMMA_MODEL=google/diffusiongemma-26b-a4b-it
MEDGEMMA_BASE_URL=
MEDGEMMA_MODEL=google/medgemma-1.5-4b-it
MEDGEMMA_API_KEY=
