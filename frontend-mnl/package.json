{
  "name": "scientific-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build && node scripts/prepare-standalone.mjs",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "start": "node scripts/start-standalone.mjs",
    "start:next": "next start -p 3001",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:qai-demo": "playwright test tests/e2e/qudrugforge-qai-recorded-demo.spec.ts --headed",
    "test:e2e:qai-proof": "playwright test tests/e2e/qudrugforge-qai-real-data-proof.spec.ts --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:live-workflow": "playwright test tests/e2e/live-scientific-workflow.spec.ts"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.6",
    "3dmol": "^2.5.4",
    "framer-motion": "^12.38.0",
    "jquery": "^4.0.0",
    "next": "16.2.9",
    "plotly.js": "^3.4.0",
    "plotly.js-basic-dist-min": "^3.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^2.6.0",
    "recharts": "^2.13.3",
    "sonner": "^2.0.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/plotly.js": "^3.0.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-plotly.js": "^2.6.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "pdf-parse": "^2.4.5",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.14",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
